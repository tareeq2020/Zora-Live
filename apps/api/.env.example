# ZORA API (NestJS)
PORT=4101

# Shared JSON data store. During migration this points at the legacy oracle's
# data dir so the api and the legacy server read/write the same files.
ZORA_DATA_DIR=../../legacy/zora-site/data

# Media library reads/writes uploaded + committed images here. During migration
# this points at the legacy site's public/assets so listings match the oracle.
ZORA_ASSETS_DIR=../../legacy/zora-site/public/assets

# White-label root domain (subdomain tenant routing)
ZORA_ROOT_DOMAIN=zora.com

# Supabase (optional). When set, events read/write the shared table instead of
# events.json. Server-only SERVICE ROLE key — never ship to the browser.
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
