# ZORA API (NestJS)
PORT=4101

# Shared JSON data store — repo root /data (post Phase-3 cutover).
ZORA_DATA_DIR=../../data

# Media library reads/writes uploaded + committed images here. Points at the web
# app's public/assets so uploads land where the site serves them.
ZORA_ASSETS_DIR=../../apps/web/public/assets

# White-label root domain (subdomain tenant routing)
ZORA_ROOT_DOMAIN=zora.com

# Session + KYC secret. Production: set this to the value in data/.session-secret
# (the KYC AES key derives from it — existing encrypted docs need the same value).
# Dev: leave unset to use the local data/.session-secret file.
# SESSION_SECRET=

# Supabase (optional). When set, events read/write the shared table instead of
# events.json. Server-only SERVICE ROLE key — never ship to the browser.
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
