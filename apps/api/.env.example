# ZORA API (NestJS)
PORT=4101

# ── Database (REQUIRED) ───────────────────────────────────────────
# Postgres is the backend for all collections. Use the Supabase SESSION-mode
# pooler URI (works on free; supports advisory locks + prepared statements).
# One string is enough for a single pm2 instance.
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# PG_POOL_MAX=10
# PG_PREPARE=false            # set only if you use the TRANSACTION pooler (:6543)

# First boot: node db/migrate.mjs  then  node db/backfill.mjs <collections>

# ── Secrets (REQUIRED — env only; the API is disk-free) ───────────
# Cookie signing (stateless session). Any strong value; rotate freely.
SESSION_SECRET=
# KYC document encryption key. MUST equal the value that encrypted existing
# .enc docs (the original 64-char .session-secret value) or they won't decrypt.
KYC_SECRET=
# Ticket QR credential signing (PR-6). Comma-separated allows key rotation — the
# verifier trusts every key in the list (retire an old one without a scanner change).
TICKET_SIGNING_KEY=
# COOKIE_SECURE=true          # set when the API is served over HTTPS

# ── Routing ───────────────────────────────────────────────────────
ZORA_ROOT_DOMAIN=zora.com

# ── Payments: x-bridge gateway (PR-8) ────────────────────────────
# ZORA talks to ONE upstream gateway ("x-bridge"), which internally routes to the
# FSPs (CLICKPESA / SELCOM / GODIGITAL). The app never calls an FSP directly.
# NOTE: ClickPesa/Selcom/GoDigital merchant credentials live INSIDE the gateway,
# NOT here — the API only holds its x-bridge key pair below.
# XBRIDGE_BASE_URL=http://localhost:3001/api   # dev default shown
# XBRIDGE_KEY_ID=              # x-bridge API key id (unset ⇒ MOCK mode)
# XBRIDGE_SECRET=              # x-bridge API secret
# XBRIDGE_MOCK=true            # force deterministic offline mocks (no token/HTTP)
# The API's OWN public https origin — the gateway payment webhook must hit the API
# host DIRECTLY (not the Vercel/Next /api rewrite, which would buffer the raw body).
# PUBLIC_ORIGIN=https://zora-api.thebrunchcity.com

# ── Delivery: SMS (PR-10) ─────────────────────────────────────────
# Driver: at (Africa's Talking, default) | beem | mock. Missing creds for a real
# driver never throws — it warns [sms:UNCONFIGURED] and dev-logs instead.
# SMS_DRIVER=at
# Africa's Talking. username=sandbox routes to their sandbox (marked dev).
# AT_API_KEY=
# AT_USERNAME=
# Beem. BEEM_API_URL defaults to https://apisms.beem.africa/v1/send
# BEEM_KEY=
# BEEM_SECRET=
# BEEM_SENDER=
# BEEM_API_URL=

# ── Delivery: Email (PR-10) ───────────────────────────────────────
# Driver is `resend` when RESEND_API_KEY is set, else `mock`. Force the mock
# (local/CI) with EMAIL_DRIVER=mock.
# EMAIL_DRIVER=mock
# RESEND_API_KEY=
# EMAIL_FROM=ZORA <tickets@zora.com>

# ── Supabase Storage (KYC + media blobs; required in production) ──
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# KYC_BUCKET=kyc-private       # private bucket for encrypted KYC documents (default shown)
# MEDIA_BUCKET=media           # public bucket for uploaded media (default shown)
