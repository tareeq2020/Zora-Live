# Copy to mobile/.env and fill from Supabase → Project Settings → API.
# EXPO_PUBLIC_* vars are inlined into the app bundle by Expo.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# KYC identity pipeline (Phase 1) — the zora-site Express server on your LAN.
# Use your PC's LAN IP (same one the Gate uses) on port 4100, or a tunnel URL.
EXPO_PUBLIC_KYC_URL=http://192.168.1.8:4100
