{
  "name": "zora",
  "version": "0.0.0",
  "private": true,
  "description": "ZORA monorepo — Next.js web + NestJS api + Expo mobile. Migration in progress; see MIGRATION-PLAN.md.",
  "packageManager": "pnpm@10.12.4",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:migrate": "node db/migrate.mjs",
    "db:media-manifest": "node db/gen-media-manifest.mjs",
    "db:test": "bash db/test/migrate.e2e.sh",
    "db:test:delivery": "pnpm --filter \"@zora/core...\" build && node packages/core/test/delivery.test.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.2",
    "dotenv": "^17.4.2",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "turbo": "^2.5.4"
  }
}
