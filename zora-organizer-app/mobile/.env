# ── Zora MOBILE app — Supabase + KYC config ──────────────────────────
# WHERE TO GET THESE: Supabase dashboard → your project →
#   Project Settings (gear icon, bottom-left) → "API" (or "API Keys")
#
#   • Project URL                → EXPO_PUBLIC_SUPABASE_URL
#         (looks like https://abcdxyzmnop.supabase.co)
#   • anon / public key          → EXPO_PUBLIC_SUPABASE_ANON_KEY
#         (newer dashboards call this the "publishable" key — same thing.
#          It's a long token starting with eyJ...  Safe to ship in the app.)
#
# Do NOT put the service_role / secret key in this file — that one is
# server-only and goes in zora-site/.env instead.
EXPO_PUBLIC_SUPABASE_URL=https://fkukeqdcyhmqckcpfxwe.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImZrdWtlcWRjeWhtcWNrY3BmeHdlIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODM3MjU2MjcsImV4cCI6MjA5OTMwMTYyN30.baXWgt2Ch4D7_4Sky06j3W94L30P4Q-676NKTmleKIo

# KYC identity pipeline → the zora-site Express server on your LAN (port 4100).
# Pre-filled with this PC's LAN IP; update if the IP ever changes.
EXPO_PUBLIC_KYC_URL=http://192.168.1.8:4100
